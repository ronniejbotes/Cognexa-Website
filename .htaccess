# .htaccess — Cognexa marketing site (Hostinger, Apache/LiteSpeed)
#
# Four concerns only:
#   1. One-hop canonical redirect to https://cognexa.co.za/
#   2. Text compression (mod_deflate)
#   3. Browser caching (mod_expires)
#   4. Security headers (mod_headers) — HSTS
#
# Keep this file lean — it is read on every request.

# ------------------------------------------------------------------
# 1. Canonical redirect — exactly ONE hop.
#
# Any of these variants:
#   http://cognexa.co.za/...      (HTTPS off)
#   http://www.cognexa.co.za/...  (HTTPS off + www)
#   https://www.cognexa.co.za/... (www)
# 301s DIRECTLY to https://cognexa.co.za/<path> in a single redirect.
# The two conditions are OR-ed so one rule handles every combination —
# this avoids the chained http→https→non-www double redirect that
# Lighthouse flags under "Avoid multiple page redirects".
# ------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\. [NC]
  RewriteRule ^(.*)$ https://cognexa.co.za/$1 [R=301,L]
</IfModule>

# ------------------------------------------------------------------
# 2. Compression — gzip the text formats this static site serves.
# (JPG and MP4 are already compressed; compressing them again wastes CPU,
# so only text types are listed. SVG is XML text, hence included.)
# ------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ------------------------------------------------------------------
# 3. Browser caching.
#   - HTML: no caching (max-age=0) — pages must update the moment we deploy,
#     and they are the entry point that references versioned assets.
#   - CSS/JS: 7 days — safe because they are referenced with ?v= cache-busters,
#     so a deploy with a bumped version bypasses the cache immediately.
#   - Images / fonts / videos: 30 days — large, rarely-changed media.
# ------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — always revalidate
  ExpiresByType text/html "access plus 0 seconds"

  # CSS/JS — 7 days (cache-busted via ?v= query strings)
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"

  # Images — 30 days
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"

  # Fonts — 30 days (self-hosted woff2; immutable files)
  ExpiresByType font/woff2 "access plus 30 days"
  ExpiresByType font/woff "access plus 30 days"

  # Videos — 30 days
  ExpiresByType video/mp4 "access plus 30 days"
  ExpiresByType video/webm "access plus 30 days"
</IfModule>

# ------------------------------------------------------------------
# 4. Security headers.
#   HSTS — tells browsers to always use HTTPS for this domain (and
#   subdomains) for one year. Only meaningful on HTTPS responses;
#   browsers ignore the header over plain HTTP, so setting it
#   unconditionally is safe.
# ------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>
